FREEMAIL_APP_NAME=FreeMail
FREEMAIL_ENV=development
FREEMAIL_HOSTNAME=freemail.kuzuryu.ai
FREEMAIL_BIND_ADDRESS=127.0.0.1
FREEMAIL_API_PORT=18090
FREEMAIL_WEB_PORT=18091
FREEMAIL_WEB_CORS_ORIGINS=http://127.0.0.1:18091,http://localhost:18091
FREEMAIL_RELEASE_VERSION=0.1.0-dev
FREEMAIL_RELEASE_COMMIT=unknown
FREEMAIL_DB_PATH=data/freemail.sqlite
FREEMAIL_SESSION_TTL_SECONDS=43200
FREEMAIL_MAX_ATTACHMENT_BYTES=1048576
FREEMAIL_ALLOWED_ATTACHMENT_CONTENT_TYPES=text/plain,text/csv,application/pdf,image/png,image/jpeg

# Stalwart candidate ports remain loopback-bound by docker-compose.yml.
FREEMAIL_SMTP_PORT=2525
FREEMAIL_SUBMISSION_PORT=2465
FREEMAIL_IMAP_PORT=2993
FREEMAIL_JMAP_PORT=18092
# Optional for local Stalwart setup. Use a real random value outside Git.
# STALWART_RECOVERY_ADMIN=admin:change-me-to-a-long-random-stalwart-recovery-password

# Replace before any real deployment. Never commit real secrets.
FREEMAIL_ADMIN_API_TOKEN=change-me-to-a-long-random-admin-api-token
FREEMAIL_BOOTSTRAP_TOKEN=change-me-to-a-long-random-bootstrap-token
FREEMAIL_SESSION_SECRET=change-me-to-a-long-random-session-encryption-secret
FREEMAIL_ADMIN_EMAIL=admin@example.com
FREEMAIL_ADMIN_PASSWORD=change-me-to-a-long-random-admin-password
