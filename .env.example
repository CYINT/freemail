FREEMAIL_APP_NAME=FreeMail
FREEMAIL_ENV=development
FREEMAIL_HOSTNAME=freemail.kuzuryu.ai
FREEMAIL_BIND_ADDRESS=127.0.0.1
FREEMAIL_API_PORT=18090
FREEMAIL_WEB_PORT=18091
FREEMAIL_RELEASE_VERSION=0.1.0-dev
FREEMAIL_RELEASE_COMMIT=unknown

# Stalwart candidate ports remain loopback-bound by docker-compose.yml.
FREEMAIL_SMTP_PORT=2525
FREEMAIL_SUBMISSION_PORT=2587
FREEMAIL_IMAP_PORT=2143
FREEMAIL_JMAP_PORT=18092

# Replace before any real deployment. Never commit real secrets.
FREEMAIL_ADMIN_EMAIL=admin@example.com
FREEMAIL_ADMIN_PASSWORD=change-me-to-a-long-random-admin-password
