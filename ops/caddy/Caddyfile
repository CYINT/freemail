:80 {
	root * /usr/share/caddy
	encode zstd gzip

	handle /.well-known/apple-app-site-association {
		reverse_proxy admin-api:8080
	}

	handle /.well-known/assetlinks.json {
		reverse_proxy admin-api:8080
	}

	file_server

	header {
		Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self' http://127.0.0.1:18090 https://freemail.kuzuryu.ai; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; object-src 'none'; script-src 'self'; style-src 'self'; upgrade-insecure-requests"
		Cross-Origin-Opener-Policy "same-origin"
		Permissions-Policy "camera=(), geolocation=(), microphone=(), payment=(), usb=()"
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
	}
}
